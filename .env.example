# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Set AI_PROVIDER to "openai" | "anthropic" | "fake"
# "fake" mode uses deterministic stub data – useful for local dev without API calls
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# If using Anthropic instead:
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Max upload size in bytes (default: 20 MB)
MAX_UPLOAD_SIZE_BYTES=20971520

# ─── Storage bucket names (must match Supabase Storage buckets) ───────────────
SUPABASE_BUCKET_UPLOADS=uploads
SUPABASE_BUCKET_OUTPUTS=outputs
